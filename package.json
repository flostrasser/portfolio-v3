{
  "name": "portfolio-v3",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "astro": "astro",
    "lint": "prettier . --check && eslint .",
    "lint:fix": "prettier . --write . && eslint . --fix",
    "type:check": "tsc --noEmit",
    "prepare": "husky",
    "test:e2e": "ASTRO_ADAPTER=node playwright test",
    "test:e2e:ui": "ASTRO_ADAPTER=node playwright test --ui",
    "test:e2e:update": "ASTRO_ADAPTER=node playwright test --update-snapshots"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/netlify": "^7.0.10",
    "@astrojs/node": "^10.1.1",
    "@tailwindcss/postcss": "^4.3.0",
    "astro": "^6.3.7",
    "postcss-preset-env": "^11.3.0",
    "sass": "^1.83.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^10.4.0",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4"
  },
  "lint-staged": {
    "*": [
      "prettier --write --ignore-unknown",
      "eslint --fix"
    ]
  }
}
