---
import type { ImageMetadata } from 'astro';
import { Picture } from 'astro:assets';
import classNames from 'classnames';

import IconLaunch from '../assets/icons/launch.svg';

export interface Props {
  isFeatured?: boolean;
  detailsFirst?: boolean;
  imageAlign?: 'bottom';
  className: string;
  title: string;
  description: string;
  technologies: string[];
  link: string;
  linkText: string;
  image: ImageMetadata;
  imageAlt: string;
}

const {
  isFeatured = false,
  detailsFirst = false,
  imageAlign,
  className,
  title,
  description,
  technologies,
  link,
  linkText,
  image,
  imageAlt,
} = Astro.props;
---

<div
  class={classNames(
    'flex max-w-xl flex-col rounded-md lg:max-w-full',
    className,
    {
      'lg:flex-row': !isFeatured,
    }
  )}
>
  <div
    class={classNames('relative', {
      'lg:flex-golden': !isFeatured,
    })}
  >
    {
      isFeatured ? (
        <Picture
          class="h-full w-full bg-black/20 object-cover"
          src={image}
          widths={[675, 1152, 1920]}
          sizes="(max-width: 639px) 90vw, (max-width: 1023px) 576px, 960px"
          formats={['avif', 'webp', 'png']}
          alt={imageAlt}
          loading="lazy"
        />
      ) : (
        <Picture
          class={classNames(
            'aspect-3/2 h-full w-full bg-black/20 object-cover lg:absolute lg:aspect-auto lg:bg-transparent',
            {
              'object-bottom': imageAlign === 'bottom',
            }
          )}
          src={image}
          widths={[675, 1152, 1187]}
          sizes="(max-width: 639px) 90vw, (max-width: 1023px) 576px, 593px"
          formats={['avif', 'webp', 'png']}
          alt={imageAlt}
          loading="lazy"
        />
      )
    }
  </div>
  <div
    class={classNames('space-y-4 p-6 sm:space-y-6 sm:p-8 lg:p-12', {
      'lg:pl-0': !isFeatured && !detailsFirst,
      'lg:order-first lg:pr-0': detailsFirst,
    })}
  >
    <h3 class="text-3xl sm:text-4xl">{title}</h3>
    <p
      class={classNames('sm:text-lg max-w-xl', {
        'lg:max-w-none': !isFeatured,
      })}
    >
      {description}
    </p>
    <ul class="font-mono leading-loose sm:text-lg">
      {technologies.map((technology) => <li>{technology}</li>)}
    </ul>
    <a class="btn btn-sm" href={link} target="_blank" rel="noreferrer">
      <span>{linkText}</span>
      <span class="sr-only">(opens in a new tab)</span>
      <IconLaunch />
    </a>
  </div>
</div>
